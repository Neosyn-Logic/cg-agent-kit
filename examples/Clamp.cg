package com.example;

// Clamp — saturate x to the range [lo, hi], Q16.16 (signed). PORT-DRIVEN so the
// two comparators + selects survive synthesis. The canonical DSP/control/graphics
// guard against overflow wrap and out-of-range values. Verified: sim ok, REAL.
task Clamp {
  in push int<32> x; in push int<32> lo; in push int<32> hi;
  out push int<32> y;
  void loop() {
    int<32> v = x.read(); int<32> l = lo.read(); int<32> h = hi.read();
    int<32> r = v;
    if (v < l) { r = l; }
    if (v > h) { r = h; }
    y.write(r);
  }
}

network Clamp_test {
  properties { test: { terminate: "monitor.finished" } }
  dut = new Clamp();
  driver = new task {
    out push int<32> x; out push int<32> lo; out push int<32> hi;
    void loop() { x.write(327680); lo.write(65536); hi.write(196608); }  // clamp 5 to [1,3] -> 3
  };
  monitor = new task {
    in push int<32> y; bool finished = false;
    void setup() { int<32> r = y.read(); print("clamp=", r, " (expect 196608=3.0)\n"); assert(r == 196608); finished = true; }
  };
  dut.reads(driver.x, driver.lo, driver.hi);
  monitor.reads(dut.y);
}
